<%- include("../partials/page-start", { pageTitle: `Narudžba #${order.id}` }) %>

<main class="mx-auto max-w-6xl space-y-6">
  <section class="rounded-3xl border border-white/10 bg-white/8 p-6 shadow-2xl shadow-slate-950/40 backdrop-blur-xl sm:p-8">
    <div class="flex flex-col gap-5 lg:flex-row lg:items-start lg:justify-between">
      <div>
        <p class="text-sm font-medium uppercase tracking-[0.24em] text-cyan-200">Narudžbe</p>
        <h1 class="mt-3 text-3xl font-semibold tracking-tight text-white sm:text-4xl">Narudžba #<%= order.id %></h1>
        <p class="mt-3 max-w-2xl text-sm leading-6 text-slate-300 sm:text-base">
          Pregled stavki narudžbe, statusa i radnji obrade.
        </p>
      </div>

      <a href="/worker/orders/purchases" class="inline-flex items-center justify-center rounded-xl border border-white/10 bg-white/5 px-4 py-3 text-sm font-semibold text-white transition hover:bg-white/10">Natrag na popis</a>
    </div>

    <% if (errors && errors.length > 0) { %>
      <div class="mt-6 rounded-2xl border border-rose-400/20 bg-rose-500/10 px-4 py-4 text-sm text-rose-200">
        <ul class="list-disc space-y-1 pl-5">
          <% errors.forEach(error => { %>
            <li><%= error %></li>
          <% }) %>
        </ul>
      </div>
    <% } %>

    <div class="mt-8 grid gap-5 md:grid-cols-2 xl:grid-cols-4">
      <div class="rounded-2xl border border-white/10 bg-slate-900/50 p-5">
        <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-400">Klijent</p>
        <p class="mt-3 text-lg font-semibold text-white"><%= order.client_name %></p>
        <p class="mt-1 text-sm text-slate-300">OIB: <%= order.client_oib %></p>
        <p class="mt-1 text-sm text-slate-300">Grad: <%= order.client_city || "N/A" %></p>
      </div>

      <div class="rounded-2xl border border-white/10 bg-slate-900/50 p-5">
        <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-400">Status</p>
        <p class="mt-3 text-lg font-semibold text-white"><%= order.status %></p>
        <p class="mt-1 text-sm text-slate-300">Datum: <%= new Date(order.created_date).toLocaleDateString("hr-HR") %></p>
      </div>

      <div class="rounded-2xl border border-white/10 bg-slate-900/50 p-5">
        <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-400">Račun</p>
        <% if (order.invoice_id) { %>
          <p class="mt-3 text-lg font-semibold text-white">#<%= order.invoice_id %></p>
          <p class="mt-1 text-sm text-slate-300"><%= new Date(order.invoice_date).toLocaleDateString("hr-HR") %></p>
        <% } else { %>
          <p class="mt-3 text-lg font-semibold text-white">Nije izdano</p>
        <% } %>
      </div>

      <div class="rounded-2xl border border-white/10 bg-slate-900/50 p-5">
        <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-400">Ukupno</p>
        <p class="mt-3 text-lg font-semibold text-white"><%= Number(order.total_amount || 0).toFixed(2) %> €</p>
        <p class="mt-1 text-sm text-slate-300">Stavki: <%= order.items.length %></p>
      </div>
    </div>

    <div class="mt-8 flex flex-wrap gap-3">
      <% if (order.status === "U obradi") { %>
        <form method="POST" action="/worker/orders/purchases/<%= order.id %>/ship">
          <button type="submit" class="inline-flex items-center justify-center rounded-xl bg-cyan-400 px-5 py-3 text-sm font-semibold text-slate-950 transition hover:bg-cyan-300">
            Označi kao poslano
          </button>
        </form>

        <form method="POST" action="/worker/orders/purchases/<%= order.id %>/reject" onsubmit="return confirm('Jeste li sigurni da želite otkazati narudžbu?');">
          <button type="submit" class="inline-flex items-center justify-center rounded-xl border border-rose-400/20 bg-rose-500/10 px-5 py-3 text-sm font-semibold text-rose-200 transition hover:bg-rose-500/20">
            Otkaži narudžbu
          </button>
        </form>
      <% } %>

      <% if (order.status === "Poslano") { %>
        <form method="POST" action="/worker/orders/purchases/<%= order.id %>/deliver">
          <button type="submit" class="inline-flex items-center justify-center rounded-xl bg-cyan-400 px-5 py-3 text-sm font-semibold text-slate-950 transition hover:bg-cyan-300">
            Označi kao isporučeno
          </button>
        </form>
      <% } %>
    </div>
  </section>

  <section class="overflow-hidden rounded-3xl border border-white/10 bg-slate-950/60 shadow-2xl shadow-slate-950/40 backdrop-blur-xl">
    <div class="border-b border-white/10 px-6 py-5">
      <h2 class="text-xl font-semibold text-white">Stavke narudžbe</h2>
    </div>

    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-white/10 text-left text-sm">
        <thead class="bg-white/5 text-slate-300">
          <tr>
            <th class="px-5 py-4 font-semibold">Artikl</th>
            <th class="px-5 py-4 font-semibold">Proizvođač</th>
            <th class="px-5 py-4 font-semibold">LOT</th>
            <th class="px-5 py-4 font-semibold">Količina</th>
            <th class="px-5 py-4 font-semibold">Jedinična cijena</th>
            <th class="px-5 py-4 font-semibold">Ukupno</th>
          </tr>
        </thead>

        <tbody class="divide-y divide-white/10">
          <% order.items.forEach(item => { %>
            <tr class="bg-slate-950/40 align-top text-slate-100">
              <td class="px-5 py-4 font-medium text-white"><%= item.article_name %></td>
              <td class="px-5 py-4 text-slate-300"><%= item.manufacturer || "N/A" %></td>
              <td class="px-5 py-4 text-slate-300"><%= item.lot_number %></td>
              <td class="px-5 py-4 text-slate-300"><%= item.quantity %></td>
              <td class="px-5 py-4 text-slate-300"><%= Number(item.unit_price).toFixed(2) %> €</td>
              <td class="px-5 py-4 text-slate-300"><%= (Number(item.quantity) * Number(item.unit_price)).toFixed(2) %> €</td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </section>
</main>

<%- include("../partials/page-end") %>
