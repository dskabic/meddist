<%- include("../partials/page-start", { pageTitle: "Dodaj artikl" }) %>

<main class="mx-auto max-w-4xl">
  <section class="rounded-3xl border border-white/10 bg-white/8 p-8 shadow-2xl shadow-slate-950/40 backdrop-blur-xl sm:p-10">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
      <div>
        <p class="text-sm font-medium uppercase tracking-[0.24em] text-cyan-200">Skladište</p>
        <h1 class="mt-3 text-3xl font-semibold tracking-tight text-white">Dodaj novi artikl</h1>
        <p class="mt-3 text-sm leading-6 text-slate-300">Ispunite osnovne podatke i po potrebi dodatne podatke za uređaj ili potrošni materijal.</p>
      </div>

      <a href="/worker/warehouse/equipment" class="inline-flex items-center justify-center rounded-xl border border-white/10 bg-white/5 px-4 py-3 text-sm font-semibold text-white transition hover:bg-white/10">Natrag na popis</a>
    </div>

    <% if (errors && errors.length > 0) { %>
      <div class="mt-6 rounded-2xl border border-rose-400/20 bg-rose-500/10 px-4 py-4 text-sm text-rose-200">
        <ul class="list-disc space-y-1 pl-5">
          <% errors.forEach(error => { %>
            <li><%= error %></li>
          <% }) %>
        </ul>
      </div>
    <% } %>

    <form method="POST" action="/worker/warehouse/equipment/create" class="mt-8 space-y-8">
      <div class="grid gap-5 md:grid-cols-2">
        <div>
          <label class="mb-2 block text-sm font-medium text-slate-200">Naziv artikla</label>
          <input type="text" name="name" value="<%= formData.name || '' %>" class="w-full rounded-xl border border-white/10 bg-slate-900/70 px-4 py-3 text-white outline-none transition focus:border-cyan-400/60 focus:ring-2 focus:ring-cyan-400/20">
        </div>

        <div>
          <label class="mb-2 block text-sm font-medium text-slate-200">Proizvođač</label>
          <input type="text" name="manufacturer" value="<%= formData.manufacturer || '' %>" class="w-full rounded-xl border border-white/10 bg-slate-900/70 px-4 py-3 text-white outline-none transition focus:border-cyan-400/60 focus:ring-2 focus:ring-cyan-400/20">
        </div>

        <div>
          <label class="mb-2 block text-sm font-medium text-slate-200">Vrsta artikla</label>
          <select name="type" class="w-full rounded-xl border border-white/10 bg-slate-900/70 px-4 py-3 text-white outline-none transition focus:border-cyan-400/60 focus:ring-2 focus:ring-cyan-400/20">
            <option value="UREDAJ" <%= formData.type === "UREDAJ" ? "selected" : "" %>>Uređaj</option>
            <option value="POTROSNI_MATERIJAL" <%= formData.type === "POTROSNI_MATERIJAL" ? "selected" : "" %>>Potrošni materijal</option>
          </select>
        </div>
      </div>

      <div class="rounded-2xl border border-white/10 bg-slate-950/50 p-6">
        <h2 class="text-lg font-semibold text-white">Podaci za uređaj</h2>
        <div class="mt-5 grid gap-5 md:grid-cols-2">
          <div>
            <label class="mb-2 block text-sm font-medium text-slate-200">Serijski broj</label>
            <input type="text" name="serialNumber" value="<%= formData.serialNumber || '' %>" class="w-full rounded-xl border border-white/10 bg-slate-900/70 px-4 py-3 text-white outline-none transition focus:border-cyan-400/60 focus:ring-2 focus:ring-cyan-400/20">
          </div>

          <div>
            <label class="mb-2 block text-sm font-medium text-slate-200">Status raspoloživosti</label>
            <select name="availabilityStatus" class="w-full rounded-xl border border-white/10 bg-slate-900/70 px-4 py-3 text-white outline-none transition focus:border-cyan-400/60 focus:ring-2 focus:ring-cyan-400/20">
              <% ["Dostupan", "Iznajmljen", "Na servisu", "Nedostupan"].forEach(status => { %>
                <option value="<%= status %>" <%= formData.availabilityStatus === status ? "selected" : "" %>><%= status %></option>
              <% }) %>
            </select>
          </div>
        </div>
      </div>

      <div class="rounded-2xl border border-white/10 bg-slate-950/50 p-6">
        <h2 class="text-lg font-semibold text-white">Podaci za potrošni materijal</h2>
        <div class="mt-5 grid gap-5 md:grid-cols-2">
          <div>
            <label class="mb-2 block text-sm font-medium text-slate-200">LOT broj</label>
            <input type="text" name="lotNumber" value="<%= formData.lotNumber || '' %>" class="w-full rounded-xl border border-white/10 bg-slate-900/70 px-4 py-3 text-white outline-none transition focus:border-cyan-400/60 focus:ring-2 focus:ring-cyan-400/20">
          </div>

          <div>
            <label class="mb-2 block text-sm font-medium text-slate-200">Trenutna zaliha</label>
            <input type="number" name="currentStock" value="<%= formData.currentStock || '' %>" class="w-full rounded-xl border border-white/10 bg-slate-900/70 px-4 py-3 text-white outline-none transition focus:border-cyan-400/60 focus:ring-2 focus:ring-cyan-400/20">
          </div>
          <div>
            <label class="mb-2 block text-sm font-medium text-slate-200">Zadana cijena najma po danu</label>
            <input
              type="number"
              step="0.01"
              name="defaultRentalPricePerDay"
              value="<%= formData.defaultRentalPricePerDay !== undefined && formData.defaultRentalPricePerDay !== null ? formData.defaultRentalPricePerDay : '' %>"
              class="w-full rounded-xl border border-white/10 bg-slate-900/70 px-4 py-3 text-white outline-none transition focus:border-cyan-400/60 focus:ring-2 focus:ring-cyan-400/20"
            >
          </div>

          <div>
            <label class="mb-2 block text-sm font-medium text-slate-200">Zadana jedinična cijena</label>
            <input
              type="number"
              step="0.01"
              name="defaultUnitPrice"
              value="<%= formData.defaultUnitPrice !== undefined && formData.defaultUnitPrice !== null ? formData.defaultUnitPrice : '' %>"
              class="w-full rounded-xl border border-white/10 bg-slate-900/70 px-4 py-3 text-white outline-none transition focus:border-cyan-400/60 focus:ring-2 focus:ring-cyan-400/20"
            >
          </div>
        </div>
      </div>

      <div class="flex justify-end">
        <button type="submit" class="inline-flex items-center justify-center rounded-xl bg-cyan-400 px-5 py-3 text-sm font-semibold text-slate-950 transition hover:bg-cyan-300">Spremi</button>
      </div>
    </form>
  </section>
</main>

<%- include("../partials/page-end") %>