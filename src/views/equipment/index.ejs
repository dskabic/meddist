<%- include("../partials/page-start", { pageTitle: "Upravljanje opremom" }) %>

<main class="mx-auto max-w-7xl space-y-6">
  <section class="rounded-3xl border border-white/10 bg-white/8 p-6 shadow-2xl shadow-slate-950/40 backdrop-blur-xl sm:p-8">
    <div class="flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between">
      <div>
        <p class="text-sm font-medium uppercase tracking-[0.24em] text-cyan-200">Skladište</p>
        <h1 class="mt-3 text-3xl font-semibold tracking-tight text-white sm:text-4xl">Upravljanje opremom</h1>
        <p class="mt-3 max-w-2xl text-sm leading-6 text-slate-300 sm:text-base">
          Pregled, uređivanje i uklanjanje artikala iz skladišnog kataloga.
        </p>
      </div>

      <div class="flex flex-wrap gap-3">
        <a href="/worker/warehouse" class="inline-flex items-center justify-center rounded-xl border border-white/10 bg-white/5 px-4 py-3 text-sm font-semibold text-white transition hover:bg-white/10">Natrag na dashboard</a>
        <a href="/worker/warehouse/equipment/create" class="inline-flex items-center justify-center rounded-xl bg-cyan-400 px-4 py-3 text-sm font-semibold text-slate-950 transition hover:bg-cyan-300">Dodaj novi artikl</a>
      </div>
    </div>

    <form method="GET" action="/worker/warehouse/equipment" class="mt-6 flex flex-col gap-3 sm:flex-row">
      <input type="text" name="search" placeholder="Pretraži po nazivu, proizvođaču, serijskom broju ili LOT broju" value="<%= search %>" class="w-full flex-1 rounded-xl border border-white/10 bg-slate-900/70 px-4 py-3 text-white outline-none transition placeholder:text-slate-500 focus:border-cyan-400/60 focus:ring-2 focus:ring-cyan-400/20">
      <div class="flex gap-3">
        <button type="submit" class="inline-flex items-center justify-center rounded-xl bg-cyan-400 px-5 py-3 text-sm font-semibold text-slate-950 transition hover:bg-cyan-300">Pretraži</button>
        <a href="/worker/warehouse/equipment" class="inline-flex items-center justify-center rounded-xl border border-white/10 bg-white/5 px-5 py-3 text-sm font-semibold text-white transition hover:bg-white/10">Očisti</a>
      </div>
    </form>
  </section>

  <section class="overflow-hidden rounded-3xl border border-white/10 bg-slate-950/60 shadow-2xl shadow-slate-950/40 backdrop-blur-xl">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-white/10 text-left text-sm">
        <thead class="bg-white/5 text-slate-300">
          <tr>
            <th class="px-5 py-4 font-semibold">ID</th>
            <th class="px-5 py-4 font-semibold">Naziv</th>
            <th class="px-5 py-4 font-semibold">Proizvođač</th>
            <th class="px-5 py-4 font-semibold">Vrsta</th>
            <th class="px-5 py-4 font-semibold">Serijski broj</th>
            <th class="px-5 py-4 font-semibold">Status</th>
            <th class="px-5 py-4 font-semibold">LOT broj</th>
            <th class="px-5 py-4 font-semibold">Zaliha</th>
            <th class="px-5 py-4 font-semibold">Zadana cijena po danu</th>
            <th class="px-5 py-4 font-semibold">Zadana jedinična cijena</th>
            <th class="px-5 py-4 font-semibold">Akcije</th>
          </tr>
        </thead>

        <tbody class="divide-y divide-white/10">
          <% if (equipment.length === 0) { %>
            <tr>
              <td colspan="9" class="px-5 py-10 text-center text-slate-300">Nema pronađenih artikala.</td>
            </tr>
          <% } %>

          <% equipment.forEach(item => { %>
            <tr class="bg-slate-950/40 align-top text-slate-100">
              <td class="px-5 py-4 text-slate-300"><%= item.id %></td>
              <td class="px-5 py-4 font-medium text-white"><%= item.name %></td>
              <td class="px-5 py-4 text-slate-300"><%= item.manufacturer || "-" %></td>
              <td class="px-5 py-4 text-slate-300">
                <% if (item.type === "UREDAJ") { %>
                  Uređaj
                <% } else if (item.type === "POTROSNI_MATERIJAL") { %>
                  Potrošni materijal
                <% } else { %>
                  Nepoznato
                <% } %>
              </td>
              <td class="px-5 py-4 text-slate-300"><%= item.serial_number || "-" %></td>
              <td class="px-5 py-4 text-slate-300"><%= item.availability_status || "-" %></td>
              <td class="px-5 py-4 text-slate-300"><%= item.lot_number || "-" %></td>
              <td class="px-5 py-4 text-slate-300"><%= item.current_stock !== null ? item.current_stock : "-" %></td>
              <td class="px-5 py-4 text-slate-300"><%= item.default_rental_price_per_day !== null ? item.default_rental_price_per_day : "-" %></td>
              <td class="px-5 py-4 text-slate-300"><%= item.default_unit_price !== null ? item.default_unit_price : "-" %></td>
              <td class="px-5 py-4">
                <div class="flex flex-wrap gap-2">
                  <a href="/worker/warehouse/equipment/<%= item.id %>/edit" class="inline-flex items-center justify-center rounded-lg border border-white/10 bg-white/5 px-3 py-2 text-xs font-semibold text-white transition hover:bg-white/10">Uredi</a>

                  <form method="POST" action="/worker/warehouse/equipment/<%= item.id %>/delete" onsubmit="return confirm('Jeste li sigurni da želite obrisati ovaj artikl?');">
                    <button type="submit" class="inline-flex items-center justify-center rounded-lg border border-rose-400/20 bg-rose-500/10 px-3 py-2 text-xs font-semibold text-rose-200 transition hover:bg-rose-500/20">Obriši</button>
                  </form>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </section>
</main>

<%- include("../partials/page-end") %>
