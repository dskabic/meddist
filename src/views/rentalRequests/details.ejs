<table border="1" cellpadding="6">
  <thead>
    <tr>
      <th>Uređaj</th>
      <th>Proizvođač</th>
      <th>Serijski broj</th>
      <th>Status uređaja</th>
      <th>Zadana cijena/dan</th>
    </tr>
  </thead>

  <tbody>
    <%- include("../partials/page-start", { pageTitle: `Detalji zahtjeva #${request.id}` }) %>

    <main class="mx-auto max-w-7xl space-y-6">
      <section class="rounded-3xl border border-white/10 bg-white/8 p-6 shadow-2xl shadow-slate-950/40 backdrop-blur-xl sm:p-8">
        <div class="flex flex-col gap-5 lg:flex-row lg:items-start lg:justify-between">
          <div>
            <p class="text-sm font-medium uppercase tracking-[0.24em] text-cyan-200">Zahtjev za najam</p>
            <h1 class="mt-3 text-3xl font-semibold tracking-tight text-white sm:text-4xl">Detalji zahtjeva #<%= request.id %></h1>
            <p class="mt-3 max-w-2xl text-sm leading-6 text-slate-300 sm:text-base">Pregled zaglavlja i svih uređaja uključenih u zahtjev.</p>
          </div>

          <a href="/worker/orders/rental-requests" class="inline-flex items-center justify-center rounded-xl border border-white/10 bg-white/5 px-4 py-3 text-sm font-semibold text-white transition hover:bg-white/10">Natrag na popis</a>
        </div>
      </section>

      <section class="grid gap-6 lg:grid-cols-[1.1fr_0.9fr]">
        <div class="rounded-3xl border border-white/10 bg-slate-950/60 p-6 shadow-2xl shadow-slate-950/40 backdrop-blur-xl sm:p-8">
          <h2 class="text-lg font-semibold text-white">Zaglavlje</h2>

          <dl class="mt-5 grid gap-4 sm:grid-cols-2">
            <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
              <dt class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-400">Klijent</dt>
              <dd class="mt-2 text-sm font-medium text-white"><%= request.client_name %></dd>
            </div>
            <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
              <dt class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-400">OIB</dt>
              <dd class="mt-2 text-sm font-medium text-white"><%= request.client_oib %></dd>
            </div>
            <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
              <dt class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-400">Grad</dt>
              <dd class="mt-2 text-sm font-medium text-white"><%= request.client_city || "-" %></dd>
            </div>
            <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
              <dt class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-400">Status</dt>
              <dd class="mt-2 text-sm font-medium text-white"><%= request.status %></dd>
            </div>
            <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
              <dt class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-400">Datum podnošenja</dt>
              <dd class="mt-2 text-sm font-medium text-white"><%= new Date(request.submitted_date).toLocaleDateString("hr-HR") %></dd>
            </div>
            <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
              <dt class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-400">Početak najma</dt>
              <dd class="mt-2 text-sm font-medium text-white"><%= new Date(request.desired_start_date).toLocaleDateString("hr-HR") %></dd>
            </div>
            <div class="rounded-2xl border border-white/10 bg-white/5 p-4 sm:col-span-2">
              <dt class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-400">Očekivani povrat</dt>
              <dd class="mt-2 text-sm font-medium text-white"><%= new Date(request.desired_return_date).toLocaleDateString("hr-HR") %></dd>
            </div>
          </dl>
        </div>

        <div class="rounded-3xl border border-white/10 bg-slate-950/60 p-6 shadow-2xl shadow-slate-950/40 backdrop-blur-xl sm:p-8">
          <h2 class="text-lg font-semibold text-white">Akcije</h2>

          <% if (request.status === "Zaprimljen") { %>
            <div class="mt-5 space-y-3">
              <a href="/worker/orders/rental-requests/<%= request.id %>/create-contract" class="inline-flex w-full items-center justify-center rounded-xl bg-cyan-400 px-4 py-3 text-sm font-semibold text-slate-950 transition hover:bg-cyan-300">Kreiraj ugovor</a>

              <form method="POST" action="/worker/orders/rental-requests/<%= request.id %>/reject" onsubmit="return confirm('Jeste li sigurni da želite odbiti zahtjev?');">
                <button type="submit" class="inline-flex w-full items-center justify-center rounded-xl border border-rose-400/20 bg-rose-500/10 px-4 py-3 text-sm font-semibold text-rose-200 transition hover:bg-rose-500/20">Odbij zahtjev</button>
              </form>
            </div>
          <% } else { %>
            <div class="mt-5 rounded-2xl border border-white/10 bg-white/5 p-4 text-sm text-slate-300">
              Zahtjev više nije u statusu Zaprimljen.
            </div>
          <% } %>
        </div>
      </section>

      <section class="overflow-hidden rounded-3xl border border-white/10 bg-slate-950/60 shadow-2xl shadow-slate-950/40 backdrop-blur-xl">
        <div class="border-b border-white/10 px-6 py-5 sm:px-8">
          <h2 class="text-lg font-semibold text-white">Stavke zahtjeva</h2>
        </div>

        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-white/10 text-left text-sm">
            <thead class="bg-white/5 text-slate-300">
              <tr>
                <th class="px-5 py-4 font-semibold">Uređaj</th>
                <th class="px-5 py-4 font-semibold">Proizvođač</th>
                <th class="px-5 py-4 font-semibold">Serijski broj</th>
                <th class="px-5 py-4 font-semibold">Status uređaja</th>
                <th class="px-5 py-4 font-semibold">Zadana cijena/dan</th>
              </tr>
            </thead>

            <tbody class="divide-y divide-white/10">
              <% request.items.forEach(item => { %>
                <tr class="bg-slate-950/40 text-slate-100">
                  <td class="px-5 py-4 font-medium text-white"><%= item.equipment_name %></td>
                  <td class="px-5 py-4 text-slate-300"><%= item.manufacturer || "-" %></td>
                  <td class="px-5 py-4 text-slate-300"><%= item.serial_number %></td>
                  <td class="px-5 py-4 text-slate-300"><%= item.availability_status %></td>
                  <td class="px-5 py-4 text-slate-300"><%= item.default_rental_price_per_day !== null ? item.default_rental_price_per_day : "-" %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </section>
    </main>

    <%- include("../partials/page-end") %>