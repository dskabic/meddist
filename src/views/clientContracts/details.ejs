<%- include("../partials/page-start", { pageTitle: `Moj ugovor #${contract.id}` }) %>

<main class="mx-auto max-w-5xl space-y-6">
  <section class="rounded-3xl border border-white/10 bg-white/8 p-6 shadow-2xl shadow-slate-950/40 backdrop-blur-xl sm:p-8">
    <div class="flex items-start justify-between gap-6">
      <div>
        <p class="text-sm font-medium uppercase tracking-[0.24em] text-cyan-200">Ugovor</p>
        <h1 class="mt-2 text-2xl font-semibold text-white">Detalji ugovora #<%= contract.id %></h1>
        <p class="mt-1 text-sm text-slate-300">Pregled zaglavlja ugovora i uređaja koji su uključeni u najam.</p>
      </div>

      <div class="hidden items-center gap-3 sm:flex">
        <a href="/client/contracts" class="inline-flex items-center justify-center rounded-xl border border-white/10 bg-white/5 px-4 py-2 text-sm font-semibold text-white transition hover:bg-white/10">Natrag na moje ugovore</a>
      </div>
    </div>
  </section>

  <% if (error) { %>
    <section class="rounded-2xl border border-rose-400/20 bg-rose-500/10 p-4 text-sm text-rose-100">
      <%= error %>
    </section>
  <% } %>

  <% if (canCancel) { %>
    <section class="rounded-2xl border border-white/8 bg-slate-950/50 p-5">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <h3 class="text-sm font-semibold text-slate-300">Otkazivanje ugovora</h3>
          <p class="mt-1 text-sm text-slate-400">Ugovor možete otkazati dok najam još nije započeo.</p>
        </div>

        <form method="POST" action="/client/contracts/<%= contract.id %>/cancel" onsubmit="return confirm('Jeste li sigurni da želite otkazati ovaj ugovor?');">
          <button type="submit" class="inline-flex items-center justify-center rounded-xl border border-rose-400/20 bg-rose-500/10 px-4 py-3 text-sm font-semibold text-rose-200 transition hover:bg-rose-500/20">Otkaži ugovor</button>
        </form>
      </div>
    </section>
  <% } %>

  <section class="grid gap-6 sm:grid-cols-2">
    <div class="rounded-2xl border border-white/8 bg-slate-950/50 p-5">
      <h3 class="text-sm font-semibold text-slate-300">Zaglavlje ugovora</h3>
      <dl class="mt-4 grid grid-cols-1 gap-y-3 gap-x-4 sm:grid-cols-2">
        <div>
          <dt class="text-xs text-slate-400">Klijent</dt>
          <dd class="mt-1 text-sm text-white"><%= contract.client_name %></dd>
        </div>
        <div>
          <dt class="text-xs text-slate-400">OIB</dt>
          <dd class="mt-1 text-sm text-white"><%= contract.client_oib %></dd>
        </div>
        <div>
          <dt class="text-xs text-slate-400">Adresa</dt>
          <dd class="mt-1 text-sm text-white"><%= contract.client_street || "-" %>, <%= contract.client_postal_code || "" %> <%= contract.client_city || "" %></dd>
        </div>
        <div>
          <dt class="text-xs text-slate-400">Email klijenta</dt>
          <dd class="mt-1 text-sm text-white"><%= contract.client_email %></dd>
        </div>
        <div>
          <dt class="text-xs text-slate-400">Djelatnik distributera</dt>
          <dd class="mt-1 text-sm text-white"><%= contract.worker_name %> (<%= contract.worker_role %>)</dd>
        </div>
        <div>
          <dt class="text-xs text-slate-400">Email djelatnika</dt>
          <dd class="mt-1 text-sm text-white"><%= contract.worker_email %></dd>
        </div>
        <div>
          <dt class="text-xs text-slate-400">Datum sklapanja</dt>
          <dd class="mt-1 text-sm text-white"><%= new Date(contract.contract_date).toLocaleDateString("hr-HR") %></dd>
        </div>
        <div>
          <dt class="text-xs text-slate-400">Status</dt>
          <dd class="mt-1 text-sm text-white"><%= contract.status %></dd>
        </div>
        <div>
          <dt class="text-xs text-slate-400">Početak najma</dt>
          <dd class="mt-1 text-sm text-white"><%= contract.rental_start_date ? new Date(contract.rental_start_date).toLocaleDateString("hr-HR") : "-" %></dd>
        </div>
        <div>
          <dt class="text-xs text-slate-400">Očekivani povrat</dt>
          <dd class="mt-1 text-sm text-white"><%= new Date(contract.expected_return_date).toLocaleDateString("hr-HR") %></dd>
        </div>
        <div>
          <dt class="text-xs text-slate-400">ID zahtjeva</dt>
          <dd class="mt-1 text-sm text-white"><%= contract.request_id %></dd>
        </div>
      </dl>
    </div>

    <div class="rounded-2xl border border-white/8 bg-slate-950/50 p-5">
      <h3 class="text-sm font-semibold text-slate-300">Stavke ugovora</h3>

      <div class="mt-4 overflow-x-auto">
        <table class="min-w-full text-left text-sm">
          <thead class="text-slate-400">
            <tr>
              <th class="px-3 py-2 font-medium">Uređaj</th>
              <th class="px-3 py-2 font-medium">Proizvođač</th>
              <th class="px-3 py-2 font-medium">Serijski broj</th>
              <th class="px-3 py-2 font-medium">Status uređaja</th>
              <th class="px-3 py-2 font-medium">Ugovorena cijena po danu</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-white/6">
            <% if (contract.items.length === 0) { %>
              <tr>
                <td colspan="5" class="px-3 py-8 text-center text-slate-300">Ugovor nema stavki.</td>
              </tr>
            <% } %>

            <% contract.items.forEach(item => { %>
              <tr class="text-white">
                <td class="px-3 py-3"><%= item.equipment_name %></td>
                <td class="px-3 py-3 text-slate-300"><%= item.manufacturer || "-" %></td>
                <td class="px-3 py-3 text-slate-300"><%= item.serial_number %></td>
                <td class="px-3 py-3 text-slate-300"><%= item.availability_status %></td>
                <td class="px-3 py-3 text-slate-300"><%= item.agreed_price_per_day %> €</td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </section>
</main>

<%- include("../partials/page-end") %>
