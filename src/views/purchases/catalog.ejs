<%- include("../partials/page-start", { pageTitle: "Kupnja potrošnog materijala" }) %>

<main class="mx-auto max-w-7xl space-y-6">
  <section class="rounded-3xl border border-white/10 bg-white/8 p-6 shadow-2xl shadow-slate-950/40 backdrop-blur-xl sm:p-8">
    <div class="flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between">
      <div>
        <p class="text-sm font-medium uppercase tracking-[0.24em] text-cyan-200">Klijent</p>
        <h1 class="mt-3 text-3xl font-semibold tracking-tight text-white sm:text-4xl">Kupnja potrošnog materijala</h1>
        <p class="mt-3 max-w-2xl text-sm leading-6 text-slate-300 sm:text-base">
          Dodajte artikle u košaricu, pošaljite narudžbu na obradu i pratite status isporuke.
        </p>
      </div>

      <a href="/client/dashboard" class="inline-flex items-center justify-center rounded-xl border border-white/10 bg-white/5 px-4 py-3 text-sm font-semibold text-white transition hover:bg-white/10">Natrag na dashboard</a>
    </div>

    <% if (errors && errors.length > 0) { %>
      <div class="mt-6 rounded-2xl border border-rose-400/20 bg-rose-500/10 px-4 py-4 text-sm text-rose-200">
        <ul class="list-disc space-y-1 pl-5">
          <% errors.forEach(error => { %>
            <li><%= error %></li>
          <% }) %>
        </ul>
      </div>
    <% } %>

    <% if (success) { %>
      <div class="mt-6 rounded-2xl border border-emerald-400/20 bg-emerald-500/10 px-4 py-4 text-sm text-emerald-200">
        <%= success %>
        <% if (orderCreated) { %>
          <span class="font-semibold"> Broj narudžbe: #<%= orderCreated.id %>.</span>
        <% } %>
      </div>
    <% } %>
  </section>

  <section class="overflow-hidden rounded-3xl border border-white/10 bg-slate-950/60 shadow-2xl shadow-slate-950/40 backdrop-blur-xl">
    <div class="border-b border-white/10 px-6 py-5">
      <h2 class="text-xl font-semibold text-white">Katalog artikala</h2>
    </div>

    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-white/10 text-left text-sm">
        <thead class="bg-white/5 text-slate-300">
          <tr>
            <th class="px-5 py-4 font-semibold">Artikl</th>
            <th class="px-5 py-4 font-semibold">Proizvođač</th>
            <th class="px-5 py-4 font-semibold">LOT</th>
            <th class="px-5 py-4 font-semibold">Zaliha</th>
            <th class="px-5 py-4 font-semibold">Jedinična cijena</th>
            <th class="px-5 py-4 font-semibold">Dodavanje u košaricu</th>
          </tr>
        </thead>

        <tbody class="divide-y divide-white/10">
          <% if (consumables.length === 0) { %>
            <tr>
              <td colspan="6" class="px-5 py-10 text-center text-slate-300">Nema aktivnih artikala za kupnju.</td>
            </tr>
          <% } %>

          <% consumables.forEach(consumable => { %>
            <tr class="bg-slate-950/40 align-top text-slate-100">
              <td class="px-5 py-4 font-medium text-white"><%= consumable.name %></td>
              <td class="px-5 py-4 text-slate-300"><%= consumable.manufacturer || "N/A" %></td>
              <td class="px-5 py-4 text-slate-300"><%= consumable.lot_number %></td>
              <td class="px-5 py-4 text-slate-300"><%= consumable.current_stock %></td>
              <td class="px-5 py-4 text-slate-300"><%= Number(consumable.default_unit_price || 0).toFixed(2) %> €</td>
              <td class="px-5 py-4">
                <form method="POST" action="/client/purchases/cart/add" class="flex flex-wrap gap-3">
                  <input type="hidden" name="articleId" value="<%= consumable.id %>">
                  <input
                    type="number"
                    name="quantity"
                    min="1"
                    value="1"
                    class="w-24 rounded-xl border border-white/10 bg-slate-900/70 px-4 py-3 text-white outline-none transition focus:border-cyan-400/60 focus:ring-2 focus:ring-cyan-400/20"
                    <%= Number(consumable.current_stock) === 0 ? "disabled" : "" %>
                  >
                  <button
                    type="submit"
                    class="inline-flex items-center justify-center rounded-xl bg-cyan-400 px-4 py-3 text-sm font-semibold text-slate-950 transition hover:bg-cyan-300 disabled:cursor-not-allowed disabled:bg-slate-700 disabled:text-slate-300"
                    <%= Number(consumable.current_stock) === 0 ? "disabled" : "" %>
                  >
                    Dodaj
                  </button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </section>

  <section class="rounded-3xl border border-white/10 bg-white/8 p-6 shadow-2xl shadow-slate-950/40 backdrop-blur-xl sm:p-8">
    <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
      <div>
        <h2 class="text-xl font-semibold text-white">Košarica</h2>
        <p class="mt-2 text-sm leading-6 text-slate-300">Narudžba se nakon potvrde šalje djelatniku za narudžbe na obradu.</p>
      </div>

      <form method="POST" action="/client/purchases/checkout">
        <button
          type="submit"
          class="inline-flex items-center justify-center rounded-xl bg-cyan-400 px-5 py-3 text-sm font-semibold text-slate-950 transition hover:bg-cyan-300 disabled:cursor-not-allowed disabled:bg-slate-700 disabled:text-slate-300"
          <%= cart.items.length === 0 ? "disabled" : "" %>
        >
          Pošalji narudžbu
        </button>
      </form>
    </div>

    <div class="mt-6 overflow-hidden rounded-2xl border border-white/10">
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-white/10 text-left text-sm">
          <thead class="bg-white/5 text-slate-300">
            <tr>
              <th class="px-5 py-4 font-semibold">Artikl</th>
              <th class="px-5 py-4 font-semibold">LOT</th>
              <th class="px-5 py-4 font-semibold">Jedinična cijena</th>
              <th class="px-5 py-4 font-semibold">Količina</th>
              <th class="px-5 py-4 font-semibold">Ukupno</th>
              <th class="px-5 py-4 font-semibold">Akcija</th>
            </tr>
          </thead>

          <tbody class="divide-y divide-white/10">
            <% if (cart.items.length === 0) { %>
              <tr>
                <td colspan="6" class="px-5 py-10 text-center text-slate-300">Košarica je prazna.</td>
              </tr>
            <% } %>

            <% cart.items.forEach(item => { %>
              <tr class="bg-slate-950/40 align-top text-slate-100">
                <td class="px-5 py-4 font-medium text-white"><%= item.articleName %></td>
                <td class="px-5 py-4 text-slate-300"><%= item.lotNumber %></td>
                <td class="px-5 py-4 text-slate-300"><%= item.unitPrice.toFixed(2) %> €</td>
                <td class="px-5 py-4">
                  <form method="POST" action="/client/purchases/cart/update" class="flex flex-wrap gap-3">
                    <input type="hidden" name="articleId" value="<%= item.articleId %>">
                    <input type="number" name="quantity" min="0" value="<%= item.quantity %>" class="w-24 rounded-xl border border-white/10 bg-slate-900/70 px-4 py-3 text-white outline-none transition focus:border-cyan-400/60 focus:ring-2 focus:ring-cyan-400/20">
                    <button type="submit" class="inline-flex items-center justify-center rounded-xl border border-white/10 bg-white/5 px-4 py-3 text-sm font-semibold text-white transition hover:bg-white/10">
                      Ažuriraj
                    </button>
                  </form>
                </td>
                <td class="px-5 py-4 text-slate-300"><%= item.subtotal.toFixed(2) %> €</td>
                <td class="px-5 py-4">
                  <form method="POST" action="/client/purchases/cart/remove">
                    <input type="hidden" name="articleId" value="<%= item.articleId %>">
                    <button type="submit" class="inline-flex items-center justify-center rounded-xl border border-rose-400/20 bg-rose-500/10 px-4 py-3 text-sm font-semibold text-rose-200 transition hover:bg-rose-500/20">
                      Ukloni
                    </button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>

          <tfoot class="bg-white/5 text-slate-100">
            <tr>
              <td colspan="4" class="px-5 py-4 text-right font-semibold">Ukupno</td>
              <td class="px-5 py-4 font-semibold"><%= cart.total.toFixed(2) %> €</td>
              <td class="px-5 py-4"></td>
            </tr>
          </tfoot>
        </table>
      </div>
    </div>
  </section>

  <section class="overflow-hidden rounded-3xl border border-white/10 bg-slate-950/60 shadow-2xl shadow-slate-950/40 backdrop-blur-xl">
    <div class="border-b border-white/10 px-6 py-5">
      <h2 class="text-xl font-semibold text-white">Moje narudžbe</h2>
    </div>

    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-white/10 text-left text-sm">
        <thead class="bg-white/5 text-slate-300">
          <tr>
            <th class="px-5 py-4 font-semibold">ID</th>
            <th class="px-5 py-4 font-semibold">Datum</th>
            <th class="px-5 py-4 font-semibold">Status</th>
            <th class="px-5 py-4 font-semibold">Broj stavki</th>
            <th class="px-5 py-4 font-semibold">Ukupan iznos</th>
            <th class="px-5 py-4 font-semibold">Račun</th>
          </tr>
        </thead>

        <tbody class="divide-y divide-white/10">
          <% if (orders.length === 0) { %>
            <tr>
              <td colspan="6" class="px-5 py-10 text-center text-slate-300">Nemate narudžbi za kupnju.</td>
            </tr>
          <% } %>

          <% orders.forEach(order => { %>
            <tr class="bg-slate-950/40 align-top text-slate-100">
              <td class="px-5 py-4 text-slate-300">#<%= order.id %></td>
              <td class="px-5 py-4 text-slate-300"><%= new Date(order.created_date).toLocaleDateString("hr-HR") %></td>
              <td class="px-5 py-4 text-slate-300"><%= order.status %></td>
              <td class="px-5 py-4 text-slate-300"><%= order.item_count %></td>
              <td class="px-5 py-4 text-slate-300"><%= Number(order.total_amount || 0).toFixed(2) %> €</td>
              <td class="px-5 py-4 text-slate-300">
                <% if (order.invoice_id) { %>
                  #<%= order.invoice_id %> / <%= new Date(order.invoice_date).toLocaleDateString("hr-HR") %>
                <% } else { %>
                  Nije izdano
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </section>
</main>

<%- include("../partials/page-end") %>
