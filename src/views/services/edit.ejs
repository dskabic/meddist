<%- include("../partials/page-start", { pageTitle: "Uredi servis" }) %>

<main class="mx-auto max-w-4xl">
  <section class="rounded-3xl border border-white/10 bg-white/8 p-8 shadow-2xl shadow-slate-950/40 backdrop-blur-xl sm:p-10">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
      <div>
        <p class="text-sm font-medium uppercase tracking-[0.24em] text-cyan-200">Servis</p>
        <h1 class="mt-3 text-3xl font-semibold tracking-tight text-white">Uredi servis</h1>
        <p class="mt-3 text-sm leading-6 text-slate-300">Ažurirajte servisni zapis i zadržite postojeću evidenciju.</p>
      </div>

      <a href="/worker/service/records" class="inline-flex items-center justify-center rounded-xl border border-white/10 bg-white/5 px-4 py-3 text-sm font-semibold text-white transition hover:bg-white/10">Natrag na popis</a>
    </div>

    <% if (errors && errors.length > 0) { %>
      <div class="mt-6 rounded-2xl border border-rose-400/20 bg-rose-500/10 px-4 py-4 text-sm text-rose-200">
        <ul class="list-disc space-y-1 pl-5">
          <% errors.forEach(error => { %>
            <li><%= error %></li>
          <% }) %>
        </ul>
      </div>
    <% } %>

    <form method="POST" action="/worker/service/records/<%= service.id %>/edit" class="mt-8 space-y-6">
      <div>
        <label class="mb-2 block text-sm font-medium text-slate-200">Uređaj</label>
        <select name="equipmentId" class="w-full rounded-xl border border-white/10 bg-slate-900/70 px-4 py-3 text-white outline-none transition focus:border-cyan-400/60 focus:ring-2 focus:ring-cyan-400/20">
          <option value="">-- Odaberite uređaj --</option>

          <% devices.forEach(device => { %>
            <option value="<%= device.id %>" <%= Number(service.equipment_id) === Number(device.id) ? "selected" : "" %>>
              <%= device.name %> - <%= device.serial_number %> - <%= device.availability_status %>
            </option>
          <% }) %>
        </select>
      </div>

      <div class="grid gap-5 md:grid-cols-2">
        <div>
          <label class="mb-2 block text-sm font-medium text-slate-200">Datum servisa</label>
          <input type="date" name="serviceDate" value="<%= service.service_date ? new Date(service.service_date).toISOString().slice(0, 10) : '' %>" class="w-full rounded-xl border border-white/10 bg-slate-900/70 px-4 py-3 text-white outline-none transition focus:border-cyan-400/60 focus:ring-2 focus:ring-cyan-400/20">
        </div>
      </div>

      <div>
        <label class="mb-2 block text-sm font-medium text-slate-200">Opis radova</label>
        <textarea name="description" rows="6" class="w-full rounded-2xl border border-white/10 bg-slate-900/70 px-4 py-3 text-white outline-none transition placeholder:text-slate-500 focus:border-cyan-400/60 focus:ring-2 focus:ring-cyan-400/20"><%= service.description || '' %></textarea>
      </div>

      <div class="flex justify-end">
        <button type="submit" class="inline-flex items-center justify-center rounded-xl bg-cyan-400 px-5 py-3 text-sm font-semibold text-slate-950 transition hover:bg-cyan-300">Spremi promjene</button>
      </div>
    </form>
  </section>
</main>

<%- include("../partials/page-end") %>