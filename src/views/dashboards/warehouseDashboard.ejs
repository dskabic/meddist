<%- include("../partials/page-start", { pageTitle: "Skladišni dashboard" }) %>

<main class="mx-auto max-w-5xl">
  <section class="app-panel p-8 sm:p-10">
    <div class="flex flex-col gap-6 lg:flex-row lg:items-start lg:justify-between">
      <div>
        <h1 class="text-3xl font-semibold tracking-tight text-white sm:text-4xl">
          Djelatnik skladišta
        </h1>

        <p class="mt-3 max-w-2xl text-sm leading-6 text-slate-300 sm:text-base">
          Dobrodošli, <%= currentUser.name %>. Ovdje upravljate opremom, zalihama i podacima o artiklima.
        </p>
      </div>

      <form method="POST" action="/logout">
        <button type="submit" class="inline-flex items-center justify-center rounded-xl border border-white/10 bg-white/5 px-5 py-3 text-sm font-semibold text-white transition hover:border-white/20 hover:bg-white/10">
          Odjava
        </button>
      </form>
    </div>

    <div class="mt-8">
      <a href="/worker/warehouse/equipment" class="group inline-flex items-center gap-3 rounded-2xl border border-white/10 bg-slate-900/60 px-6 py-4 text-sm font-semibold text-slate-100 transition hover:border-slate-400/40 hover:bg-slate-800">
        Upravljanje opremom
        <span class="transition group-hover:translate-x-1">→</span>
      </a>
    </div>
  </section>
</main>

<%- include("../partials/page-end") %>
