<%- include("../partials/page-start", { pageTitle: "Servisni dashboard" }) %>

<main class="mx-auto max-w-5xl">
  <section class="app-panel p-8 sm:p-10">
    <div class="flex flex-col gap-6 lg:flex-row lg:items-start lg:justify-between">
      <div>
        <h1 class="text-3xl font-semibold tracking-tight text-white sm:text-4xl">
          Servisni djelatnik
        </h1>

        <p class="mt-3 max-w-2xl text-sm leading-6 text-slate-300 sm:text-base">
          Dobrodošli, <%= currentUser.name %>. Ovdje upravljate servisnim zapisima i završetkom servisa.
        </p>
      </div>

      <% if (currentUser.role === "Administrator") { %>
        <a href="/worker/admin" class="inline-flex items-center justify-center rounded-xl border border-white/10 bg-white/5 px-5 py-3 text-sm font-semibold text-white transition hover:border-white/20 hover:bg-white/10">
          Natrag na admin
        </a>
      <% } %>
    </div>

    <div class="mt-8">
      <a href="/worker/service/records" class="group inline-flex items-center gap-3 rounded-2xl border border-white/10 bg-slate-900/60 px-6 py-4 text-sm font-semibold text-slate-100 transition hover:border-slate-400/40 hover:bg-slate-800">
        Upravljanje servisima uređaja
        <span class="transition group-hover:translate-x-1">→</span>
      </a>
    </div>
  </section>
</main>

<%- include("../partials/page-end") %>
