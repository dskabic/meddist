<%- include("../partials/page-start", { pageTitle: "Narudžbe" }) %>

<main class="mx-auto max-w-5xl">
  <section class="rounded-3xl border border-white/10 bg-white/8 p-8 shadow-2xl shadow-slate-950/40 backdrop-blur-xl sm:p-10">
    <div class="flex flex-col gap-6 lg:flex-row lg:items-start lg:justify-between">
      <div>
        <span class="inline-flex items-center rounded-full border border-cyan-400/20 bg-cyan-400/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.24em] text-cyan-200">
          Narudžbe
        </span>

        <h1 class="mt-5 text-3xl font-semibold tracking-tight text-white sm:text-4xl">
          Djelatnik za narudžbe
        </h1>

        <p class="mt-3 max-w-2xl text-sm leading-6 text-slate-300 sm:text-base">
          Dobrodošli, <%= currentUser.name %>. Ovaj prostor je predviđen za pregled i obradu narudžbi.
        </p>
      </div>


      <form method="POST" action="/logout">
        <button type="submit" class="inline-flex items-center justify-center rounded-xl border border-white/10 bg-white/5 px-5 py-3 text-sm font-semibold text-white transition hover:border-white/20 hover:bg-white/10">
          Odjava
        </button>
      </form>
    </div>

    <div class="mt-8 grid gap-4 md:grid-cols-3">
      <div class="rounded-2xl border border-white/10 bg-slate-900/60 p-6">
        <h2 class="text-lg font-semibold text-white">Pregled</h2>
        <p class="mt-2 text-sm leading-6 text-slate-300">Popis svih narudžbi.</p>
      </div>

      <div class="rounded-2xl border border-white/10 bg-slate-900/60 p-6">
        <h2 class="text-lg font-semibold text-white">Obrada</h2>
        <a href="/worker/orders/rental-requests">Zahtjevi za najam</a>
        <p class="mt-2 text-sm leading-6 text-slate-300">Statusi i radni tok narudžbi.</p>
      </div>

      <div class="rounded-2xl border border-white/10 bg-slate-900/60 p-6">
        <h2 class="text-lg font-semibold text-white">Računi</h2>
        <p class="mt-2 text-sm leading-6 text-slate-300">Izdavanje i evidencija računa.</p>
      </div>
    </div>
  </section>
</main>

<%- include("../partials/page-end") %>