<%- include("../partials/page-start", { pageTitle: "Narudžbe" }) %>

<main class="mx-auto max-w-5xl">
  <section class="app-panel p-8 sm:p-10">
    <div class="flex flex-col gap-6 lg:flex-row lg:items-start lg:justify-between">
      <div>
        <h1 class="text-3xl font-semibold tracking-tight text-white sm:text-4xl">
          Djelatnik za narudžbe
        </h1>

        <p class="mt-3 max-w-2xl text-sm leading-6 text-slate-300 sm:text-base">
          Dobrodošli, <%= currentUser.name %>. Ovaj prostor je predviđen za pregled i obradu narudžbi.
        </p>
      </div>


      <form method="POST" action="/logout">
        <button type="submit" class="inline-flex items-center justify-center rounded-xl border border-white/10 bg-white/5 px-5 py-3 text-sm font-semibold text-white transition hover:border-white/20 hover:bg-white/10">
          Odjava
        </button>
      </form>
    </div>

    <div class="mt-8 grid gap-4 md:grid-cols-3">
      <a href="/worker/orders/contracts" class="app-card block rounded-2xl border border-white/10 bg-slate-900/60 p-6 transition">
        <h2 class="text-lg font-semibold text-white">Popis ugovora o najmu</h2>
        <p class="mt-2 text-sm leading-6 text-slate-300">Pregled svih ugovora o najmu.</p>
      </a>

      <a href="/worker/orders/rental-requests" class="app-card block rounded-2xl border border-white/10 bg-slate-900/60 p-6 transition">
        <h2 class="text-lg font-semibold text-white">Zahtjevi za najam</h2>
        <p class="mt-2 text-sm leading-6 text-slate-300">Pregled i obrada zahtjeva za najam.</p>
      </a>
      <a href="/worker/orders/purchases" class="app-card block rounded-2xl border border-white/10 bg-slate-900/60 p-6 transition">
        <h2 class="text-lg font-semibold text-white">Kupovne narudžbe</h2>
        <p class="mt-2 text-sm leading-6 text-slate-300">Pregled, slanje i isporuka narudžbi potrošnog materijala.</p>
      </a>
    </div>
  </section>
</main>

<%- include("../partials/page-end") %>
