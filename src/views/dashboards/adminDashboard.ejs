<%- include("../partials/page-start", { pageTitle: "Administrator" }) %>

<main class="mx-auto max-w-6xl">
  <section class="app-panel p-8 sm:p-10">
    <div>
      <h1 class="text-3xl font-semibold tracking-tight text-white sm:text-4xl">
        Administrator
      </h1>

      <p class="mt-3 max-w-2xl text-sm leading-6 text-slate-300 sm:text-base">
        Dobrodošli, <%= currentUser.name %>. Ovdje upravljate glavnim administrativnim područjima sustava.
      </p>
    </div>

    <div class="mt-8 grid gap-4 md:grid-cols-3">
      <a href="/worker/orders" class="app-card group block rounded-2xl border border-white/10 bg-slate-900/60 p-6 transition">
        <h2 class="text-lg font-semibold text-white">Narudžbe</h2>
        <p class="mt-2 text-sm leading-6 text-slate-300">Pregled zahtjeva za najam i kupovnih narudžbi.</p>
      </a>

      <a href="/worker/warehouse" class="app-card group block rounded-2xl border border-white/10 bg-slate-900/60 p-6 transition">
        <h2 class="text-lg font-semibold text-white">Skladište</h2>
        <p class="mt-2 text-sm leading-6 text-slate-300">Upravljanje opremom i zalihama.</p>
      </a>

      <a href="/worker/service" class="app-card group block rounded-2xl border border-white/10 bg-slate-900/60 p-6 transition">
        <h2 class="text-lg font-semibold text-white">Servis</h2>
        <p class="mt-2 text-sm leading-6 text-slate-300">Evidencija i završavanje servisnih zapisa.</p>
      </a>
    </div>
  </section>
</main>

<%- include("../partials/page-end") %>
