<%- include("../partials/page-start", { pageTitle: "Klijentski dashboard" }) %>

<main class="mx-auto max-w-5xl">
  <section class="app-panel p-8 sm:p-10">
    <div class="flex flex-col gap-6 lg:flex-row lg:items-start lg:justify-between">
      <div>
        <h1 class="text-3xl font-semibold tracking-tight text-white sm:text-4xl">
          Klijentski dio aplikacije
        </h1>

        <p class="mt-3 max-w-2xl text-sm leading-6 text-slate-300 sm:text-base">
          Dobrodošli, <%= currentUser.name %>. Ovdje možete pregledati ključne klijentske mogućnosti sustava.
        </p>
      </div>

      <form method="POST" action="/logout">
        <button type="submit" class="inline-flex items-center justify-center rounded-xl border border-white/10 bg-white/5 px-5 py-3 text-sm font-semibold text-white transition hover:border-white/20 hover:bg-white/10">
          Odjava
        </button>
      </form>
    </div>

    <div class="mt-8 grid gap-4 md:grid-cols-3">
      <a href="/client/products" class="app-card block rounded-2xl border border-white/10 bg-slate-900/60 p-6 transition">
        <h2 class="text-lg font-semibold text-white">Pregled dostupnih artikala</h2>
        <p class="mt-2 text-sm leading-6 text-slate-300">Pregled i pretraživanje dostupnih artikala za najam.</p>
      </a>
      <a href="/client/rental-requests" class="app-card block rounded-2xl border border-white/10 bg-slate-900/60 p-6 transition">
        <h2 class="text-lg font-semibold text-white">Zahtjevi za najam</h2>
        <p class="mt-2 text-sm leading-6 text-slate-300">Stvaranje zahtjeva za najam.</p>
      </a>
      <a href="/client/contracts" class="app-card block rounded-2xl border border-white/10 bg-slate-900/60 p-6 transition">
        <h2 class="text-lg font-semibold text-white">Ugovori o najmu</h2>
        <p class="mt-2 text-sm leading-6 text-slate-300">Pregled sklopljenih ugovora i mogućnost otkazivanja prije početka najma.</p>
      </a>
      <a href="/client/purchases" class="app-card block rounded-2xl border border-white/10 bg-slate-900/60 p-6 transition">
        <h2 class="text-lg font-semibold text-white">Kupnja potrošnog materijala</h2>
        <p class="mt-2 text-sm leading-6 text-slate-300">Košarica, slanje narudžbi i praćenje njihovog statusa.</p>
      </a>
    </div>

  </section>
</main>

<%- include("../partials/page-end") %>
