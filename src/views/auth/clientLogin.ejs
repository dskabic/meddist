<%- include("../partials/page-start", { pageTitle: "Prijava korisnika" }) %>

<main class="mx-auto flex min-h-[calc(100vh-4rem)] max-w-xl items-center">
  <section class="w-full rounded-3xl border border-white/10 bg-white/8 p-8 shadow-2xl shadow-slate-950/40 backdrop-blur-xl sm:p-10">
    <div>
      <span class="inline-flex items-center rounded-full border border-cyan-400/20 bg-cyan-400/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.24em] text-cyan-200">
        Klijent
      </span>

      <h1 class="mt-6 text-3xl font-semibold tracking-tight text-white">
        Prijava korisnika
      </h1>

      <p class="mt-3 text-sm leading-6 text-slate-300">
        Unesite svoje vjerodajnice kako biste pristupili klijentskom dijelu aplikacije.
      </p>
    </div>

    <% if (error) { %>
      <div class="mt-6 rounded-2xl border border-rose-400/20 bg-rose-500/10 px-4 py-3 text-sm text-rose-200">
        <%= error %>
      </div>
    <% } %>

    <form method="POST" action="/login/client" class="mt-8 space-y-5">
      <div>
        <label class="mb-2 block text-sm font-medium text-slate-200">Email</label>
        <input type="email" name="email" required class="w-full rounded-xl border border-white/10 bg-slate-900/70 px-4 py-3 text-white outline-none transition placeholder:text-slate-500 focus:border-cyan-400/60 focus:ring-2 focus:ring-cyan-400/20">
      </div>

      <div>
        <label class="mb-2 block text-sm font-medium text-slate-200">Lozinka</label>
        <input type="password" name="password" required class="w-full rounded-xl border border-white/10 bg-slate-900/70 px-4 py-3 text-white outline-none transition placeholder:text-slate-500 focus:border-cyan-400/60 focus:ring-2 focus:ring-cyan-400/20">
      </div>

      <div class="flex items-center justify-between gap-4 pt-2">
        <a href="/login" class="text-sm font-medium text-slate-300 transition hover:text-white">Natrag</a>
        <button type="submit" class="inline-flex items-center justify-center rounded-xl bg-cyan-400 px-5 py-3 text-sm font-semibold text-slate-950 transition hover:bg-cyan-300">
          Prijava
        </button>
      </div>
    </form>
  </section>
</main>

<%- include("../partials/page-end") %>