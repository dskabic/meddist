<%- include("../partials/page-start", { pageTitle: "Popis ugovora o najmu" }) %>

<main class="mx-auto max-w-7xl space-y-6">
  <section class="rounded-3xl border border-white/10 bg-white/8 p-6 shadow-2xl shadow-slate-950/40 backdrop-blur-xl sm:p-8">
    <div class="flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between">
      <div>
        <p class="text-sm font-medium uppercase tracking-[0.24em] text-cyan-200">Ugovori</p>
        <h1 class="mt-3 text-3xl font-semibold tracking-tight text-white sm:text-4xl">Popis ugovora o najmu</h1>
        <p class="mt-3 max-w-2xl text-sm leading-6 text-slate-300 sm:text-base">Pregled svih sklopljenih ugovora i kratak izračun troškova.</p>
      </div>

      <a href="/worker/orders" class="inline-flex items-center justify-center rounded-xl border border-white/10 bg-white/5 px-4 py-3 text-sm font-semibold text-white transition hover:bg-white/10">Natrag na dashboard</a>
    </div>

    <form method="GET" action="/worker/orders/contracts" class="mt-6 flex flex-col gap-3 sm:flex-row">
      <input type="text" name="search" placeholder="Pretraži po klijentu, OIB-u, djelatniku ili statusu" value="<%= search %>" class="w-full flex-1 rounded-xl border border-white/10 bg-slate-900/70 px-4 py-3 text-white outline-none transition placeholder:text-slate-500 focus:border-cyan-400/60 focus:ring-2 focus:ring-cyan-400/20">
      <div class="flex gap-3">
        <button type="submit" class="inline-flex items-center justify-center rounded-xl bg-cyan-400 px-5 py-3 text-sm font-semibold text-slate-950 transition hover:bg-cyan-300">Pretraži</button>
        <a href="/worker/orders/contracts" class="inline-flex items-center justify-center rounded-xl border border-white/10 bg-white/5 px-5 py-3 text-sm font-semibold text-white transition hover:bg-white/10">Očisti</a>
      </div>
    </form>
  </section>

  <section class="overflow-hidden rounded-3xl border border-white/10 bg-slate-950/60 shadow-2xl shadow-slate-950/40 backdrop-blur-xl">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-white/10 text-left text-sm">
        <thead class="bg-white/5 text-slate-300">
          <tr>
            <th class="px-5 py-4 font-semibold">ID</th>
            <th class="px-5 py-4 font-semibold">Klijent</th>
            <th class="px-5 py-4 font-semibold">OIB</th>
            <th class="px-5 py-4 font-semibold">Datum sklapanja</th>
            <th class="px-5 py-4 font-semibold">Početak najma</th>
            <th class="px-5 py-4 font-semibold">Očekivani povrat</th>
            <th class="px-5 py-4 font-semibold">Status</th>
            <th class="px-5 py-4 font-semibold">Broj stavki</th>
            <th class="px-5 py-4 font-semibold">Dnevni iznos</th>
            <th class="px-5 py-4 font-semibold">Akcija</th>
          </tr>
        </thead>

        <tbody class="divide-y divide-white/10">
          <% if (contracts.length === 0) { %>
            <tr>
              <td colspan="10" class="px-5 py-10 text-center text-slate-300">Nema ugovora.</td>
            </tr>
          <% } %>

          <% contracts.forEach(contract => { %>
            <tr class="bg-slate-950/40 align-top text-slate-100">
              <td class="px-5 py-4 text-slate-300"><%= contract.id %></td>
              <td class="px-5 py-4 font-medium text-white"><%= contract.client_name %></td>
              <td class="px-5 py-4 text-slate-300"><%= contract.client_oib %></td>
              <td class="px-5 py-4 text-slate-300"><%= new Date(contract.contract_date).toLocaleDateString("hr-HR") %></td>
              <td class="px-5 py-4 text-slate-300"><%= contract.rental_start_date ? new Date(contract.rental_start_date).toLocaleDateString("hr-HR") : "-" %></td>
              <td class="px-5 py-4 text-slate-300"><%= new Date(contract.expected_return_date).toLocaleDateString("hr-HR") %></td>
              <td class="px-5 py-4 text-slate-300"><%= contract.status %></td>
              <td class="px-5 py-4 text-slate-300"><%= contract.item_count %></td>
              <td class="px-5 py-4 text-slate-300"><%= contract.daily_total %> €</td>
              <td class="px-5 py-4">
                <a href="/worker/orders/contracts/<%= contract.id %>" class="inline-flex items-center justify-center rounded-lg border border-white/10 bg-white/5 px-3 py-2 text-xs font-semibold text-white transition hover:bg-white/10">Detalji</a>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </section>
</main>

<%- include("../partials/page-end") %>
