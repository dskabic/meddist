<!DOCTYPE html>
<html lang="hr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof pageTitle !== "undefined" ? pageTitle : "SDMU" %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    body {
      background: #111827;
      color: #e2e8f0;
    }

    .rounded-3xl { border-radius: 12px !important; }
    .rounded-2xl { border-radius: 10px !important; }
    .rounded-xl,
    .rounded-lg { border-radius: 8px !important; }

    .shadow-2xl,
    .shadow-slate-950\/40 {
      box-shadow: none !important;
    }

    .backdrop-blur-xl {
      backdrop-filter: none !important;
    }

    .bg-white\/8,
    .bg-white\/5,
    .bg-slate-900\/60,
    .bg-slate-950\/60 {
      background-color: rgba(17, 24, 39, 0.92) !important;
    }

    .app-top-link {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 38px;
      padding: 0 14px;
      border: 1px solid rgba(148, 163, 184, 0.25);
      background: rgba(17, 24, 39, 0.92);
      color: #e2e8f0;
      font-size: 0.875rem;
      font-weight: 600;
      text-decoration: none;
    }

    .app-top-form {
      margin: 0;
    }

    .app-top-user {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .app-panel {
      border: 1px solid rgba(148, 163, 184, 0.14);
      background: rgba(17, 24, 39, 0.92);
    }

    .app-button-primary {
      background: #334155 !important;
      color: #f8fafc !important;
    }

    .app-button-primary:hover {
      background: #475569 !important;
    }

    .app-card:hover {
      border-color: rgba(148, 163, 184, 0.3) !important;
      background: rgba(30, 41, 59, 0.95) !important;
    }
  </style>
</head>
<body class="min-h-screen bg-slate-950 text-slate-100 antialiased">
  <div class="relative mx-auto w-full max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <header class="mb-6 flex items-center justify-end border-b border-white/10 pb-4">
      <% if (currentUser) { %>
        <div class="app-top-user">
          <span class="text-sm text-slate-400"><%= currentUser.name %></span>
          <form method="POST" action="/logout" class="app-top-form">
            <button type="submit" class="app-top-link">Odjava</button>
          </form>
        </div>
      <% } %>
    </header>
