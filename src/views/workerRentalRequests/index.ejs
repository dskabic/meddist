<%- include("../partials/page-start", { pageTitle: "Popis zahtjeva za najam" }) %>

<main class="mx-auto max-w-7xl space-y-6">
  <section class="rounded-3xl border border-white/10 bg-white/8 p-6 shadow-2xl shadow-slate-950/40 backdrop-blur-xl sm:p-8">
    <div class="flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between">
      <div>
        <p class="text-sm font-medium uppercase tracking-[0.24em] text-cyan-200">Narudžbe</p>
        <h1 class="mt-3 text-3xl font-semibold tracking-tight text-white sm:text-4xl">Popis zahtjeva za najam</h1>
        <p class="mt-3 max-w-2xl text-sm leading-6 text-slate-300 sm:text-base">Brzi pregled zaprimljenih zahtjeva i njihovog trenutnog statusa.</p>
      </div>

      <a href="/worker/orders" class="inline-flex items-center justify-center rounded-xl border border-white/10 bg-white/5 px-4 py-3 text-sm font-semibold text-white transition hover:bg-white/10">Natrag na dashboard</a>
    </div>

    <form method="GET" action="/worker/orders/rental-requests" class="mt-6 flex flex-col gap-3 sm:flex-row">
      <input type="text" name="search" placeholder="Pretraži po ustanovi ili statusu" value="<%= search %>" class="w-full flex-1 rounded-xl border border-white/10 bg-slate-900/70 px-4 py-3 text-white outline-none transition placeholder:text-slate-500 focus:border-cyan-400/60 focus:ring-2 focus:ring-cyan-400/20">
      <div class="flex gap-3">
        <button type="submit" class="inline-flex items-center justify-center rounded-xl bg-cyan-400 px-5 py-3 text-sm font-semibold text-slate-950 transition hover:bg-cyan-300">Pretraži</button>
        <a href="/worker/orders/rental-requests" class="inline-flex items-center justify-center rounded-xl border border-white/10 bg-white/5 px-5 py-3 text-sm font-semibold text-white transition hover:bg-white/10">Očisti</a>
      </div>
    </form>
  </section>

  <section class="overflow-hidden rounded-3xl border border-white/10 bg-slate-950/60 shadow-2xl shadow-slate-950/40 backdrop-blur-xl">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-white/10 text-left text-sm">
        <thead class="bg-white/5 text-slate-300">
          <tr>
            <th class="px-5 py-4 font-semibold">ID</th>
            <th class="px-5 py-4 font-semibold">Klijent</th>
            <th class="px-5 py-4 font-semibold">Datum podnošenja</th>
            <th class="px-5 py-4 font-semibold">Početak najma</th>
            <th class="px-5 py-4 font-semibold">Povrat</th>
            <th class="px-5 py-4 font-semibold">Status</th>
            <th class="px-5 py-4 font-semibold">Broj uređaja</th>
            <th class="px-5 py-4 font-semibold">Akcije</th>
          </tr>
        </thead>

        <tbody class="divide-y divide-white/10">
          <% if (requests.length === 0) { %>
            <tr>
              <td colspan="8" class="px-5 py-10 text-center text-slate-300">Nema zahtjeva za najam.</td>
            </tr>
          <% } %>

          <% requests.forEach(request => { %>
            <tr class="bg-slate-950/40 align-top text-slate-100">
              <td class="px-5 py-4 text-slate-300"><%= request.id %></td>
              <td class="px-5 py-4 font-medium text-white"><%= request.client_name %></td>
              <td class="px-5 py-4 text-slate-300"><%= new Date(request.submitted_date).toLocaleDateString("hr-HR") %></td>
              <td class="px-5 py-4 text-slate-300"><%= new Date(request.desired_start_date).toLocaleDateString("hr-HR") %></td>
              <td class="px-5 py-4 text-slate-300"><%= new Date(request.desired_return_date).toLocaleDateString("hr-HR") %></td>
              <td class="px-5 py-4 text-slate-300"><%= request.status %></td>
              <td class="px-5 py-4 text-slate-300"><%= request.item_count %></td>
              <td class="px-5 py-4">
                <% if (request.status === "Zaprimljen") { %>
                  <div class="flex flex-wrap gap-2">
                    <a href="/worker/orders/rental-requests/<%= request.id %>/create-contract" class="inline-flex items-center justify-center rounded-lg border border-white/10 bg-white/5 px-3 py-2 text-xs font-semibold text-white transition hover:bg-white/10">Pregledaj</a>

                    <form method="POST" action="/worker/orders/rental-requests/<%= request.id %>/reject" onsubmit="return confirm('Jeste li sigurni da želite odbiti zahtjev?');">
                      <button type="submit" class="inline-flex items-center justify-center rounded-lg border border-rose-400/20 bg-rose-500/10 px-3 py-2 text-xs font-semibold text-rose-200 transition hover:bg-rose-500/20">Odbij</button>
                    </form>
                  </div>
                <% } else { %>
                  <span class="inline-flex items-center rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs font-semibold text-slate-300">Nije dostupno</span>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </section>
</main>

<%- include("../partials/page-end") %>
